{
  "name": "blog.yuo.be",
  "private": true,
  "description": "Reupen’s blog",
  "version": "1.0.0",
  "author": "Reupen Shah",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/reupen/blog.yuo.be"
  },
  "scripts": {
    "astro": "astro",
    "check": "astro check --minimumFailingSeverity hint",
    "clean": "shx rm -rf dist node_modules/.astro",
    "build": "astro build",
    "postbuild": "python scripts/subset_fonts.py",
    "dev": "astro dev",
    "format:check": "prettier -c .",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "npm run lint -- --fix",
    "preview": "astro preview",
    "start": "astro dev",
    "pretest": "npm run build",
    "test": "python scripts/run_in_playwright_container.py \"npm ci && npm exec --no -- playwright test\"",
    "test:report": "playwright show-report test/e2e/output/html",
    "pretest:update": "npm run build",
    "test:update": "python scripts/run_in_playwright_container.py \"npm ci && npm exec --no -- playwright test --update-snapshots\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdoc": "^2.0.1",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@floating-ui/react": "^0.27.17",
    "@floating-ui/react-dom": "^2.1.7",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@yeskunall/astro-umami": "^0.0.8",
    "astro": "^7.0.4",
    "downshift": "^9.3.2",
    "ky": "^1.14.3",
    "mime": "^4.1.0",
    "p-limit": "^7.3.0",
    "prop-types": "^15.8.1",
    "query-string": "^9.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-merge-refs": "^3.0.2",
    "remeda": "^2.39.0",
    "satori": "^0.19.2",
    "swr": "^2.4.0",
    "typescript": "^6.0.3",
    "ultrahtml": "^1.6.0"
  },
  "devDependencies": {
    "@astrojs/compiler-rs": "^0.3.0",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/markdown-satteri": "^0.3.2",
    "@axe-core/playwright": "^4.11.1",
    "@date-fns/tz": "^1.4.1",
    "@eslint-react/eslint-plugin": "^5.7.5",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.58.2",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^22.19.11",
    "@typescript-eslint/parser": "^8.60.0",
    "astro-compress": "^2.4.1",
    "cssnano": "^8.0.2",
    "date-fns": "^4.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-mdx": "^3.7.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "globals": "^17.3.0",
    "html-to-text": "^9.0.5",
    "postcss-custom-media": "^12.0.1",
    "postcss-preset-env": "^11.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-external-links": "^3.0.0",
    "sass": "^1.97.3",
    "schema-dts": "^2.0.0",
    "sharp": "^0.35.1",
    "typescript-eslint": "^8.60.0"
  },
  "overrides": {
    "astro": "$astro",
    "sharp": "$sharp",
    "typescript": "$typescript"
  }
}
